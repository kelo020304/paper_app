{
  "name": "paper-vault",
  "version": "0.4.0",
  "description": "Paper Orbit — a local-first arXiv research library with GitHub sync",
  "main": "src/main.js",
  "author": {
    "name": "kelo020304",
    "email": "118870984+kelo020304@users.noreply.github.com"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "dev.papervault.desktop",
    "productName": "Paper Orbit",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "category": "Office",
      "icon": "assets/icon.png",
      "target": ["AppImage", "deb"]
    }
  }
}
